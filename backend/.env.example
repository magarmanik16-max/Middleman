# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/developercloud

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Generate a strong secret: openssl rand -base64 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Gmail SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# Proxmox API Configuration
PROXMOX_API_URL=https://your-proxmox-server:8006
PROXMOX_API_TOKEN=your-proxmox-api-token
PROXMOX_API_SECRET=your-proxmox-api-secret

# Proxmox SSH Configuration (for container user provisioning)
# The backend SSHs into the Proxmox host to run pct exec commands.
# Required for automatic sudo user creation in containers.
PROXMOX_SSH_HOST=192.168.55.1
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASSWORD=
# PROXMOX_SSH_KEY=/path/to/ssh/private/key

# Application Configuration
PORT=5000
NODE_ENV=development
ALLOWED_EMAIL_DOMAIN=@timesglobal.com.np
DEFAULT_WORKSPACE_CPU=1
DEFAULT_WORKSPACE_MEMORY=512
DEFAULT_WORKSPACE_DISK=10
MAX_WORKSPACES_PER_USER=1