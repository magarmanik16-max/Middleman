# Copy to .env and fill in real values. Used by docker-compose.yml.
# Backend-specific vars also live in backend/.env (see backend/.env.example).

# JWT (must be a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars-long
# Generate a strong secret: openssl rand -base64 64

# Gmail SMTP (used by backend to send OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-gmail-app-password

# Proxmox VE
PROXMOX_API_URL=https://your-proxmox-server:8006
PROXMOX_API_TOKEN=your-proxmox-api-token
PROXMOX_API_SECRET=your-proxmox-api-secret
